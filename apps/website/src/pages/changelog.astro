---
import { readFileSync } from "node:fs";
import { fileURLToPath } from "node:url";
import Layout from "../layouts/Layout.astro";

// CHANGELOG.md at the repo root is maintained by release-please: each merged
// release PR appends a version block. This page re-renders it at build time,
// and the site redeploys on every push to main, so a merged release PR
// publishes here automatically.
const changelogPath = fileURLToPath(new URL("../../../../CHANGELOG.md", import.meta.url));
const raw = readFileSync(changelogPath, "utf-8");

interface Section {
  title: string;
  items: string[];
}
interface Release {
  version: string;
  compareUrl: string | null;
  date: string | null;
  sections: Section[];
}

function escapeHtml(text: string): string {
  return text.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
}

/** The inline markdown release-please emits: links, bold, inline code. */
function inlineHtml(text: string): string {
  return escapeHtml(text)
    .replace(/`([^`]+)`/g, "<code>$1</code>")
    .replace(/\[([^\]]+)\]\(([^)\s]+)\)/g, '<a href="$2">$1</a>')
    .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>");
}

// Release-please version headings look like `## [0.3.0](compare-url) (2026-07-17)`
// (the first release in a repo may have no compare link).
const headingPattern = /^##\s+(?:\[([^\]]+)\]\(([^)]+)\)|(\S+))(?:\s+\((\d{4}-\d{2}-\d{2})\))?/;

const releases: Release[] = [];
for (const line of raw.split("\n")) {
  const heading = line.match(headingPattern);
  if (heading) {
    releases.push({
      version: heading[1] ?? heading[3],
      compareUrl: heading[2] ?? null,
      date: heading[4] ?? null,
      sections: [],
    });
    continue;
  }
  const current = releases.at(-1);
  if (!current) continue;
  const section = line.match(/^###\s+(.+)/);
  if (section) {
    current.sections.push({ title: section[1].trim(), items: [] });
    continue;
  }
  const item = line.match(/^\*\s+(.+)/);
  if (item && current.sections.length > 0) {
    current.sections.at(-1)!.items.push(item[1].trim());
  }
}

function formatDate(date: string | null): string | null {
  if (!date) return null;
  return new Date(`${date}T00:00:00Z`).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  });
}

/** Split a leading `**scope:**` marker off an item so it can render as a chip. */
function splitScope(item: string): { scope: string | null; rest: string } {
  const match = item.match(/^\*\*([^*]+):\*\*\s*(.*)$/);
  return match ? { scope: match[1], rest: match[2] } : { scope: null, rest: item };
}
---
<Layout title="Changelog" description="Every lawlint release: what changed, and the pull requests behind each change.">
  <section class="changelog">
    <div class="eyebrow">Changelog / Releases</div>
    <h1>What changed.</h1>
    <p class="intro">
      Every release, with the pull request behind each change. Assembled automatically
      from merged work — the same notes ship with each
      <a href="https://github.com/sethtjf/lawlint/releases">GitHub release</a>.
    </p>

    {releases.map((release) => (
      <article class="release" id={`v${release.version}`}>
        <header>
          <h2>
            {release.compareUrl
              ? <a href={release.compareUrl}>v{release.version}</a>
              : <span>v{release.version}</span>}
          </h2>
          {formatDate(release.date) && <time datetime={release.date}>{formatDate(release.date)}</time>}
        </header>
        {release.sections.map((section) => (
          <div class="section">
            <div class="section-label">{section.title}</div>
            <ul>
              {section.items.map((item) => {
                const { scope, rest } = splitScope(item);
                return (
                  <li>
                    {scope && <span class="scope">{scope}</span>}
                    <span set:html={inlineHtml(rest)} />
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </article>
    ))}
  </section>
</Layout>
<style>
  .changelog { padding: 6rem 0; max-width: 48rem; }
  .changelog h1 { margin-top: 1rem; }
  .intro { color: var(--muted); font-size: 1.25rem; margin: 2rem 0 4rem; }
  .intro a { color: inherit; }
  .release { border-top: 1px solid var(--line); padding: 2rem 0 2.5rem; }
  .release header { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; }
  .release h2 { font-size: 2rem; margin: 0; }
  .release h2 a { text-decoration: none; }
  .release h2 a:hover { color: var(--oxblood); text-decoration: underline; text-decoration-thickness: 1px; }
  .release time { color: var(--muted); font: 0.72rem "IBM Plex Mono", monospace; text-transform: uppercase; letter-spacing: 0.06em; white-space: nowrap; }
  .section { margin-top: 1.6rem; }
  .section-label { color: var(--oxblood); font: 0.7rem "IBM Plex Mono", monospace; text-transform: uppercase; letter-spacing: 0.1em; }
  .section ul { list-style: none; margin: 0.8rem 0 0; padding: 0; }
  .section li { display: flex; gap: 0.7rem; align-items: baseline; padding: 0.55rem 0; border-top: 1px solid color-mix(in srgb, var(--line) 45%, transparent); font-size: 1rem; }
  .section li:first-child { border-top: 0; }
  .scope { flex-shrink: 0; color: var(--oxblood); font: 0.7rem "IBM Plex Mono", monospace; text-transform: uppercase; letter-spacing: 0.05em; border: 1px solid color-mix(in srgb, var(--oxblood) 35%, transparent); padding: 0.1rem 0.45rem; }
  .section li :global(a) { font-size: 0.85em; color: var(--muted); }
  .section li :global(a:hover) { color: var(--oxblood); }
  .section li :global(code) { font: 0.86em "IBM Plex Mono", monospace; background: var(--paper-deep); padding: 0.05em 0.3em; }
  @media (max-width: 600px) {
    .changelog { padding: 4rem 0; }
    .release header { flex-direction: column; gap: 0.3rem; }
    .section li { flex-wrap: wrap; }
  }
</style>

---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}
const { title, description = "A linter for AI-generated legal and general text." } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title} — lawlint</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="site-header">
      <a class="wordmark" href="/">lawlint<span>.</span></a>
      <nav aria-label="Primary">
        <a href="/playground">Playground</a>
        <a href="/download">Download</a>
        <a href="/docs/getting-started">Docs</a>
        <a href="/rules">Rules</a>
        <a href="https://github.com/sethtjf/lawlint">GitHub ↗</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>lawlint — writing, made human.</span>
      <span>MIT licensed</span>
    </footer>
  </body>
</html>
<style is:global>
  :root {
    --paper: #f5f0e7;
    --paper-deep: #e9e0d2;
    --ink: #211e1b;
    --muted: #756d64;
    --line: #cfc4b5;
    --oxblood: #7e2528;
    --measure: 68rem;
    font-family: "Source Serif 4", Georgia, serif;
    color: var(--ink);
    background: var(--paper);
  }
  * { box-sizing: border-box; }
  html { background: var(--paper); }
  body { margin: 0; min-width: 320px; }
  a { color: inherit; text-decoration-thickness: 1px; text-underline-offset: 0.18em; }
  a:hover { color: var(--oxblood); }
  .site-header, .site-footer { max-width: var(--measure); margin: 0 auto; padding: 1.5rem 1.5rem; display: flex; justify-content: space-between; align-items: baseline; border-bottom: 1px solid var(--line); }
  .site-footer { margin-top: 6rem; border-top: 1px solid var(--line); border-bottom: 0; color: var(--muted); font: 0.72rem "IBM Plex Mono", monospace; text-transform: uppercase; letter-spacing: 0.04em; }
  .wordmark { font-size: 1.35rem; font-weight: 700; text-decoration: none; letter-spacing: -0.03em; }
  .wordmark span { color: var(--oxblood); }
  nav { display: flex; gap: 1.4rem; font: 0.76rem "IBM Plex Mono", monospace; text-transform: uppercase; letter-spacing: 0.04em; }
  main { max-width: var(--measure); margin: 0 auto; padding: 0 1.5rem; }
  h1, h2, h3 { text-wrap: balance; line-height: 1.04; margin: 0 0 1.2rem; }
  h1 { font-size: clamp(3.4rem, 9vw, 7.8rem); letter-spacing: -0.065em; max-width: 10ch; }
  h2 { font-size: clamp(2rem, 4vw, 3.4rem); letter-spacing: -0.045em; }
  h3 { font-size: 1.5rem; }
  p, li { text-wrap: pretty; line-height: 1.6; font-size: 1.05rem; }
  .eyebrow { color: var(--oxblood); font: 0.72rem "IBM Plex Mono", monospace; text-transform: uppercase; letter-spacing: 0.13em; }
  .rule { border-top: 1px solid var(--line); padding-top: 0.7rem; }
  .button { display: inline-block; padding: 0.8rem 1.1rem; background: var(--oxblood); color: var(--paper); text-decoration: none; font: 0.75rem "IBM Plex Mono", monospace; text-transform: uppercase; letter-spacing: 0.06em; }
  .button.secondary { background: transparent; color: var(--ink); border: 1px solid var(--ink); }
  .code, pre { background: var(--ink); color: #eee5d7; font: 0.82rem/1.65 "IBM Plex Mono", monospace; padding: 1.2rem 1.3rem; overflow-x: auto; }
  .doc, .rules, .rule-doc { padding: 6rem 0; }
  .doc { max-width: 48rem; }
  .doc h1, .rule-doc h1, .rules h1 { margin-top: 1rem; }
  .doc h2, .rule-doc h2 { font-size: 2rem; margin-top: 3.5rem; }
  .doc .intro, .rule-doc .intro, .rules .intro { color: var(--muted); font-size: 1.25rem; margin: 2rem 0 4rem; }
  .doc li { margin: 0.8rem 0; }
  .doc code, .rule-doc code { font: 0.86em "IBM Plex Mono", monospace; }
  @media (max-width: 600px) { .site-header { align-items: flex-start; gap: 1rem; } nav { gap: 0.7rem; flex-wrap: wrap; justify-content: flex-end; } .site-footer { display: block; line-height: 2; } }
</style>

{
  "name": "lawlint",
  "version": "0.1.0",
  "description": "Lint AI-generated legal and general text.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sethtjf/lawlint.git",
    "directory": "packages/lawlint"
  },
  "homepage": "https://lawlint.dev",
  "keywords": ["lint", "linter", "prose", "legal", "ai", "writing"],
  "type": "module",
  "bin": {
    "lawlint": "./dist/cli.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs"
    }
  },
  "files": ["dist"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5"
  }
}

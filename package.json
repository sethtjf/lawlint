{
  "name": "lawlint",
  "private": true,
  "version": "0.1.0",
  "description": "A linter for AI-generated legal and general text.",
  "packageManager": "bun@1.3.14",
  "workspaces": ["apps/*"],
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "wasm:build": "bash scripts/build-wasm.sh",
    "build": "bun run --cwd apps/website build",
    "dev": "bun run --cwd apps/website dev",
    "desktop:dev": "bun run --cwd apps/desktop tauri dev",
    "desktop:build": "bun run --cwd apps/desktop tauri build",
    "lint": "bunx biome check apps/website",
    "typecheck": "bun run wasm:build && bunx tsc --noEmit -p apps/website/tsconfig.json",
    "test": "cargo test --workspace",
    "sync-agent-config": "bash scripts/sync-agent-config.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.2"
  }
}
